generator client {
   provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Developer {
  id Int @id @default(autoincrement())
  nome String
  githubUrl String @unique
  projects Project[]
}

model Project {
  id Int @id @default(autoincrement())
  titulo String
  descricao String
  tecnologiaPrincipal String
  developerId Int 
  developer Developer @relation(fields: [developerId], references: [id])
}
